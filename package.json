{
  "name": "@comunical/guard",
  "version": "0.1.0",
  "description": "Middleware for AI agent tool execution — context-aware trust boundaries in multi-party interactions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "trust",
    "security",
    "middleware",
    "jsonata",
    "tool-execution"
  ],
  "author": "Comunical",
  "license": "MIT",
  "dependencies": {
    "jsonata": "^2.1.0",
    "zod": "^3.24.0"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  }
}
